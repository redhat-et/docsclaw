FROM golang:1.25-alpine AS builder

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o docsclaw ./cmd/docsclaw

FROM alpine:3.23

RUN apk add --no-cache poppler-utils ca-certificates \
    && rm -rf /var/cache/apk/*

COPY --from=builder /build/docsclaw /usr/local/bin/docsclaw

USER 65534:65534

EXPOSE 8000 8100

ENTRYPOINT ["docsclaw"]
CMD ["serve"]
